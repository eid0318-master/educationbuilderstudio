# Firebase (클라이언트)
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id

# Firebase Admin (서버)
# Service Account JSON을 한 줄로 변환하여 입력
FIREBASE_ADMIN_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# Cloud SQL (PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Google Cloud Storage
GCS_PROJECT_ID=your-project-id
GCS_BUCKET_NAME=education-builder-materials
# Service Account JSON을 한 줄로 변환하여 입력
GCS_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# Gemini AI (File Search 포함)
GEMINI_API_KEY=your-gemini-api-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
